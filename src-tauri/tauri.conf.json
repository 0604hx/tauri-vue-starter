{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Tauri Vue Starter",
    "version": "../package.json",
    "identifier": "org.tauri.vue.starter",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5000",
        "beforeDevCommand": "bun ui",
        "beforeBuildCommand": "bun ui:build"
    },
    "app": {
        "windows": [
            {
                "title": "Tauri Vue Starter",
                "width": 960,
                "height": 640,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null,
            "capabilities": [
                {
                    "identifier": "capability",
                    "windows": [ "main" ],
                    "permissions": [
                        "core:window:allow-set-title"
                    ]
                }
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
